# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (matches all levels in monorepo)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
packages/app/coverage/
packages/app/playwright-report/
packages/app/test-results/
packages/app/tests/e2e/.auth/

# next.js
packages/app/.next/
packages/app/out/

# build output
packages/shared/dist/
packages/bot/dist/
packages/bot/recordings/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!packages/app/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
packages/app/next-env.d.ts
